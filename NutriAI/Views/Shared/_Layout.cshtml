@using NutriAI.Domain.Constants
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    <title>@ViewData["Title"] - NutriAI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-nutri sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="@(User.IsInRole(Roles.Admin) ? "Admin" : "Dashboard")" asp-action="Index">
                <i class="fas fa-leaf me-2"></i>NutriAI
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (User.IsInRole(Roles.User))
                    {
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-chart-pie me-1"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "MealTracker" ? "active" : "")"
                           asp-controller="MealTracker" asp-action="Index">
                            <i class="fas fa-utensils me-1"></i> Meal Tracker
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "Weight" ? "active" : "")"
                           asp-controller="Weight" asp-action="Index">
                            <i class="fas fa-weight-scale me-1"></i> Weight
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "Water" ? "active" : "")"
                           asp-controller="Water" asp-action="Index">
                            <i class="fas fa-droplet me-1"></i> Water
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "MealPlanner" ? "active" : "")"
                           asp-controller="MealPlanner" asp-action="Index">
                            <i class="fas fa-calendar-week me-1"></i> Meal Planner
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "Recipe" ? "active" : "")"
                           asp-controller="Recipe" asp-action="Index">
                            <i class="fas fa-book-open me-1"></i> Recipe Analyzer
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "Report" ? "active" : "")"
                           asp-controller="Report" asp-action="Index">
                            <i class="fas fa-file-lines me-1"></i> Reports
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "Profile" ? "active" : "")"
                           asp-controller="Profile" asp-action="Index">
                            <i class="fas fa-user me-1"></i> Profile
                        </a>
                    </li>
                    }
                </ul>
                <div class="d-flex align-items-center gap-2">
                    @if (User.IsInRole(Roles.Admin))
                    {
                    <a class="nav-link small-text @(ViewData["ActiveNav"]?.ToString() == "Admin" ? "active" : "")"
                       asp-controller="Admin" asp-action="Index">
                        <i class="fas fa-shield-halved me-1"></i> Admin
                    </a>
                    }
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-logout">
                            <i class="fas fa-right-from-bracket me-1"></i> Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-nutri">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 mb-3 mb-md-0">
                    <strong class="text-success"><i class="fas fa-leaf me-1"></i>NutriAI</strong>
                    <p class="small-text text-muted mb-0 mt-1">AI-powered nutrition tracking</p>
                </div>
                <div class="col-md-4 text-md-center mb-3 mb-md-0">
                    <a asp-controller="Dashboard" asp-action="Index" class="me-3">Dashboard</a>
                    <a asp-controller="Profile" asp-action="Index" class="me-3">Profile</a>
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
                <div class="col-md-4 text-md-end">
                    <p class="small-text text-muted mb-0">&copy; @DateTime.Now.Year NutriAI. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


