@model NutriAI.ViewModels.Admin.AiSettingsViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["ActiveNav"] = "Admin";
}

<div class="page-header fade-in">
    <h1>Admin Dashboard</h1>
    <p class="subtitle">Platform health, users, and activity</p>
</div>

<partial name="_AiSettings" model="Model" />

<div class="row g-4 mb-4" id="adminStats"></div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card-nutri mb-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
                <h3 class="h5 mb-0">Users</h3>
                <div class="d-flex gap-2 flex-wrap">
                    <input type="search" class="form-control form-control-nutri" id="userSearch" placeholder="Search users..." style="max-width:220px" />
                    <button type="button" class="btn btn-nutri btn-sm" id="btnAddUser"><i class="fas fa-plus me-1"></i>Add user</button>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-nutri table-hover mb-0">
                    <thead>
                        <tr><th>Name</th><th>Email</th><th>Status</th><th>Meals</th><th>Joined</th><th></th></tr>
                    </thead>
                    <tbody id="usersTableBody"></tbody>
                </table>
            </div>
            <nav class="mt-3">
                <ul class="pagination justify-content-center mb-0" id="usersPagination"></ul>
            </nav>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card-nutri mb-4">
            <h3 class="h6 mb-3">Activity panels</h3>
            <div class="list-group list-group-flush" id="adminSideNav">
                <button type="button" class="list-group-item list-group-item-action active" data-panel="meals">Meal logs</button>
                <button type="button" class="list-group-item list-group-item-action" data-panel="recipes">Recipe analyses</button>
                <button type="button" class="list-group-item list-group-item-action" data-panel="reports">Weekly reports</button>
            </div>
        </div>
        <div class="card-nutri">
            <h3 class="h6 mb-3" id="activityPanelTitle">Meal logs</h3>
            <div id="activityPanelContent" class="small-text"></div>
            <nav class="mt-2">
                <ul class="pagination pagination-sm justify-content-center mb-0" id="activityPagination"></ul>
            </nav>
        </div>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userModalTitle">User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="userId" />
                    <div class="mb-3">
                        <label class="form-label">Full name</label>
                        <input type="text" class="form-control form-control-nutri" id="userFullName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control form-control-nutri" id="userEmail" required />
                    </div>
                    <div class="mb-3" id="passwordField">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control form-control-nutri" id="userPassword" minlength="6" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-nutri" id="btnSaveUser">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin.js" asp-append-version="true"></script>
}

