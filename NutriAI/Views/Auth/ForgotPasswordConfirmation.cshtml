@{ Layout = "_AuthLayout"; ViewData["Title"] = "Email Sent"; }
<div class="auth-wrapper">
    <div class="auth-card text-center">
        <h2 class="h4 text-success">Check your email</h2>
        <p class="text-muted">If an account exists, we sent a password reset link.</p>
        <a asp-action="Login" class="btn btn-primary-nutri mt-3">Back to Login</a>
    </div>
</div>
