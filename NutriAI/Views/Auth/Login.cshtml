@model LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="brand">
            <h2><i class="fas fa-leaf"></i> NutriAI</h2>
            <p>Welcome back! Sign in to continue.</p>
        </div>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (Model.ShowEmailConfirmationWarning)
        {
            <div class="alert alert-warning">
                <strong>Email not confirmed.</strong>
                Please confirm your email before signing in. Check your inbox for the confirmation link.
            </div>
            <form asp-action="ResendConfirmation" method="post" class="mb-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.PendingConfirmationEmail" />
                <button type="submit" class="btn btn-outline-nutri w-100">
                    Resend Confirmation Email
                </button>
            </form>
        }
        <form asp-action="Login" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control form-control-nutri" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger small-text"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="Password" class="form-control form-control-nutri" id="password" />
                    <span class="input-group-text password-toggle" id="togglePassword"><i class="fas fa-eye"></i></span>
                </div>
                <span asp-validation-for="Password" class="text-danger small-text"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            <button type="submit" class="btn btn-primary-nutri w-100 mb-2">Sign In</button>
            <p class="text-center small-text mb-2">
                <a asp-action="ForgotPassword">Forgot password?</a>
            </p>
            <p class="text-center small-text text-muted mb-0">
                Don't have an account? <a asp-action="Register" class="text-success fw-semibold">Register</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/auth.js" asp-append-version="true"></script>
}
