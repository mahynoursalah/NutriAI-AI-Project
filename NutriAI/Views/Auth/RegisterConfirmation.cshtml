@{ Layout = "_AuthLayout"; ViewData["Title"] = "Confirm Email"; }
<div class="auth-wrapper">
    <div class="auth-card text-center">
        <h2 class="h4 text-success">Confirm your email</h2>
        <p class="text-muted">@TempData["Success"]</p>
        <p class="small-text">We sent a confirmation link to your email address.</p>
        @if (!string.IsNullOrEmpty(ViewData["RegisteredEmail"] as string))
        {
            <form asp-action="ResendConfirmation" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@ViewData["RegisteredEmail"]" />
                <button type="submit" class="btn btn-outline-nutri w-100">Resend confirmation email</button>
            </form>
        }
        <p class="small-text mt-3 mb-0">
            <a asp-action="Login" class="text-success fw-semibold">Back to sign in</a>
        </p>
    </div>
</div>
