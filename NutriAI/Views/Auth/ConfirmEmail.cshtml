@{ Layout = "_AuthLayout"; ViewData["Title"] = "Email Confirmation"; var success = (bool?)ViewData["Success"] == true; }
<div class="auth-wrapper">
    <div class="auth-card text-center">
        @if (success)
        {
            <h2 class="h4 text-success">Email confirmed</h2>
            <p>@ViewData["Message"]</p>
            <a asp-action="Login" class="btn btn-primary-nutri mt-3">Sign In</a>
        }
        else
        {
            <h2 class="h4 text-danger">Confirmation failed</h2>
            <p class="text-muted">@ViewData["Message"]</p>
            <a asp-action="ResendConfirmation" class="btn btn-outline-nutri mt-3">Resend confirmation</a>
        }
    </div>
</div>
