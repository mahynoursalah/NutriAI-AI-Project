# Copy to .env in this folder (NutriAI solution root) and fill values.
# This file is safe to commit. Do NOT commit .env or NutriAI/Data/openai-settings.json (API keys).
# Admin → AI Settings also writes OpenAI__* values to .env and Data/openai-settings.json on save.
ConnectionStrings__DefaultConnection=Data Source=.;Initial Catalog=Nutri_DB;Integrated Security=True;Encrypt=True;TrustServerCertificate=True;
AppSettings__BaseUrl=https://localhost:7029
OpenAI__ApiKey=your-openai-api-key-here
OpenAI__Model=gpt-4o-mini
OpenAI__BaseUrl=https://api.openai.com/v1
EmailSettings__SenderEmail=your-email@gmail.com
EmailSettings__SenderName=NutriAI
EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__Port=587
EmailSettings__SenderPassword=your-app-password
EmailSettings__EnableSsl=true
AdminSeed__Email=admin@nutriai.com
AdminSeed__Password=ChangeMe!Admin123
AdminSeed__FullName=System Admin
